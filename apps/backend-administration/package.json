{
  "name": "@taptime/backend-administration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "C3C tenant-safe setup plus C3E1 Employee enrollment and C3E2 NFC reassignment coordinators.",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --external:@taptime/administration-contract --external:@taptime/backend-identity --external:@taptime/core --external:pg --sourcemap --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@taptime/administration-contract": "*",
    "@taptime/backend-identity": "*",
    "@taptime/core": "*",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@taptime/backend-lifecycle": "*",
    "@taptime/backend-schema": "*",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
