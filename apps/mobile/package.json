{
  "name": "@taptime/mobile",
  "version": "1.0.0",
  "description": "TapTim.e Mobile app with C1 authentication, C2 private transport, C3E1 Employee enrollment, and an explicit development-only demo path.",
  "main": "index.ts",
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@supabase/supabase-js": "^2.110.3",
    "@taptime/core": "*",
    "@taptime/offline-sync-contract": "*",
    "expo": "~57.0.2",
    "expo-background-task": "~57.0.5",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-network": "~57.0.1",
    "expo-secure-store": "~57.0.0",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-task-manager": "~57.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:synthetic-e2e:build": "node scripts/buildSyntheticE2eAndroid.mjs",
    "android:synthetic-e2e:disconnect": "node scripts/disconnectSyntheticE2eAndroid.mjs",
    "android:synthetic-e2e:install": "node scripts/installSyntheticE2eAndroid.mjs",
    "android:offline-storage-boundary:verify": "node scripts/verifyOfflineStorageAndroidBoundary.mjs",
    "ios": "expo start --ios",
    "web": "expo start --web",
