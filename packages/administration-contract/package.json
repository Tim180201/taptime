{
  "name": "@taptime/administration-contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Neutral Unicode 15.1 name and C3 command-digest contracts shared by bootstrap and normal administration.",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --target=node24 --format=esm --sourcemap --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@unicode/unicode-15.1.0": "1.6.17"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
